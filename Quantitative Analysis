# Bar chart: average volatility
# Clean asset labels for consistency
volatility_summary["asset"] = volatility_summary["asset"].replace({
    "sol": "SOL",
    "eth": "ETH",
    "sp500": "S&P 500",
    "nasdaq": "NASDAQ",
    "gold": "Gold",
    "CRUDE OIL": "Crude Oil"
})

# Bar chart
ax = volatility_summary.plot(
    x="asset",
    y="avg_volatility_7d",
    kind="bar",
    legend=False
)

plt.title("Average 7-Day Volatility Across Asset Classes")
plt.xlabel("Asset")
plt.ylabel("Average 7-Day Volatility")
plt.xticks(rotation=30)

# Add value labels on top of bars
for i, v in enumerate(volatility_summary["avg_volatility_7d"]):
    plt.text(i, v + 0.001, f"{v:.3f}", ha='center')

plt.tight_layout()

